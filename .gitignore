# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
loam-*.tar

# Temporary files, for example, from tests.
/tmp/

# Design journal is a local working artifact, not a published spec.
# PRDs, tasks, and RFCs under docs/ are tracked; the journal is not.
/docs/journal/

# Local TLA+ tools (downloaded; not part of the repo).
/_tla/

# TLC writes the entire reachable state graph to states/<timestamp>/
# next to the spec on every run. Multi-GB; never useful in version
# control. Regenerated by re-running the model checker.
docs/specs/*/states/
